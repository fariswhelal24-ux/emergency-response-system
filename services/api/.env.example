PORT=4100
HOST=0.0.0.0
NODE_ENV=development
DATABASE_URL=postgresql://your_local_db_user@localhost:5432/emergency_response
# Add explicit tunnel origins if needed. In development, app.ts also allows trycloudflare.com, loca.lt, and ngrok hosts.
# Expo: run pnpm run dev:public:unified — scripts set EXPO_PUBLIC_API_BASE_URL, EXPO_PUBLIC_API_URL, and often EXPO_PUBLIC_WS_BASE_URL.
CLIENT_ORIGINS=http://localhost:5173,http://localhost:19000,http://localhost:19001,http://localhost:8081
JWT_ACCESS_SECRET=change_this_access_secret_at_least_16_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_at_least_16_chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_VOICE_ANALYSIS_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
AI_VOICE_ASSISTANT_TIMEOUT_MS=8000
AI_VOICE_CONVERSATION_TIMEOUT_MS=4500
AI_VOICE_FIELD_EXTRACTION_TIMEOUT_MS=4500
